<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Product Page Wireframe</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
        }

        .header, .footer {
            background-color: lightgray;
            text-align: center;
            padding: 20px;
            border: 1px solid black;
        }

        .container {
            display: flex;
            padding: 20px;
            gap: 20px;
        }

        .product-image {
            width: 40%;
            height: 300px;
            border: 1px solid black;
            background-color: #f0f0f0;
            text-align: center;
            line-height: 300px;
        }

        .product-details {
            width: 60%;
            border: 1px solid black;
            padding: 20px;
        }

        .button {
            display: inline-block;
            padding: 10px 20px;
            border: 1px solid black;
            background-color: #ddd;
            cursor: pointer;
        }

        .description {
            margin: 20px;
            padding: 20px;
            border: 1px solid black;
        }

        .related-products {
            display: flex;
            justify-content: space-around;
            margin: 20px;
        }

        .product-box {
            width: 30%;
            height: 120px;
            border: 1px solid black;
            background-color: #f0f0f0;
            text-align: center;
            line-height: 120px;
        }
    </style>
</head>
<body>

    <div class="header">
        <h2>HEADER / LOGO</h2>
    </div>

    <div class="container">
        <div class="product-image">
            PRODUCT IMAGE
        </div>

        <div class="product-details">
            <h2>Product Name</h2>
            <p>Price: $99.99</p>
            <p>Short product description.</p>
            <div class="button">Add to Cart</div>
        </div>
    </div>

    <div class="description">
        <h3>Product Description</h3>
        <p>Detailed product information goes here.</p>
    </div>

    <div class="related-products">
        <div class="product-box">Product 1</div>
        <div class="product-box">Product 2</div>
        <div class="product-box">Product 3</div>
    </div>

    <div class="footer">
        FOOTER
    </div>

</body>
</html>